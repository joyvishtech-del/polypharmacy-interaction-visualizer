# =====================================================================
# Polypharmacy Interaction Visualizer — environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# ---------- Database ----------
DATABASE_URL=postgresql://polypharmacy:devpassword@postgres:5432/polypharmacy
POSTGRES_USER=polypharmacy
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=polypharmacy

# ---------- Auth ----------
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh-token cookie transport
# COOKIE_SECURE must be true in production (HTTPS only).
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# Application environment ("development" enables dev-only logs such as the
# password-reset URL emitted by /forgot-password).
ENVIRONMENT=development

# ---------- Google OAuth (post-MVP) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Anthropic (LLM) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---------- OCR ----------
TESSERACT_PATH=/usr/bin/tesseract

# ---------- Object Storage (S3-compatible; MinIO for dev) ----------
S3_BUCKET=polypharmacy-photos
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://minio:9000

# ---------- CORS / Frontend ----------
FRONTEND_ORIGIN=http://localhost:3000
VITE_API_URL=http://localhost:8000
